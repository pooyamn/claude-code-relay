#!/usr/bin/env bash
# Per-folder persistent, resumable Claude relay: one dedicated Claude session per
# project folder. Reopens (resumes) the SAME conversation even after the tmux
# session or the whole machine dies, via Claude Code's per-folder `--continue`.
#
# Usage: claude-relay-group <WORKDIR> "<prompt>"
#   WORKDIR  - the project folder this group/session is bound to
#
# The folder IS the durable key: same folder -> same Claude conversation, forever.
set -uo pipefail
DIR="/Users/pouya/.openclaw/workspace/scripts"
RAW="${1:?usage: claude-relay-group <WORKDIR> \"<prompt>\"}"; shift
WORKDIR="$(cd "$RAW" 2>/dev/null && pwd)" || { echo "claude-relay-group: no such folder: $RAW" >&2; exit 1; }
KEY="cr-$(printf '%s' "$WORKDIR" | md5 | cut -c1-10)"   # stable per-folder tmux name

# "Alive" = the claude TUI is running in ANY usable state: idle input box, busy
# turn, OR an open selection menu. Crucially we must NOT treat an open menu as
# dead, or the session (and the menu) gets killed right before a button pick.
# NOTE: an ALT backend (`cc model ik3` -> kimi) renders NONE of claude's chrome. Its
# input bar carries a "context: N% (a/b)" gauge instead. Without that alternation a
# healthy kimi session reads as dead here and gets killed + replaced by claude on the
# very next message -- which is exactly what silently broke ik3 (the session came back
# as claude while the backend marker still said kimi, so the watcher scraped a claude
# pane with the kimi parser and delivered nothing).
ready(){ tmux capture-pane -t "$KEY" -p 2>/dev/null | grep -qE "for agents|for shortcuts|esc to interrupt|Esc to cancel|to navigate|❯ +[0-9]+\.|context: *[0-9.]+% *\("; }

if ! ( tmux has-session -t "$KEY" 2>/dev/null && ready ); then
  tmux kill-session -t "$KEY" 2>/dev/null || true
  # resume the folder's existing conversation if one exists, else start fresh
  ENC="$(printf '%s' "$WORKDIR" | sed 's#[/.]#-#g')"
  CONT=""
  ls "$HOME/.claude/projects/$ENC"/*.jsonl >/dev/null 2>&1 && CONT="--continue"
  tmux new-session -d -s "$KEY" -x 200 -y 50
  # Per-folder session, but global memory + global skills stay loaded (Pouya wants
  # them available in bound sessions). --settings pins auto-memory to the global
  # memory dir so it loads regardless of the folder's own git root; skills load by
  # default. Isolation is just the separate folder/session.
  SETTINGS="/Users/pouya/.openclaw/workspace/scripts/relay-claude-settings.json"
  # This path ALWAYS (re)launches claude, so the session's backend marker must be
  # reset to claude. Leaving a stale `kimi` marker here makes the watcher parse a
  # claude pane with the kimi parser -> extracts nothing -> replies never delivered.
  printf '{"backend": "claude"}' \
    > "/Users/pouya/.openclaw/workspace/scripts/relay-work/backend-$KEY.json" 2>/dev/null || true
  tmux send-keys -t "$KEY" "cd $WORKDIR && claude $CONT --settings $SETTINGS --dangerously-skip-permissions" Enter
  for i in $(seq 1 90); do
    sleep 1
    pane="$(tmux capture-pane -t "$KEY" -p 2>/dev/null || true)"
    if printf '%s' "$pane" | grep -q "trust this folder"; then
      tmux send-keys -t "$KEY" Enter; sleep 2
    fi
    if printf '%s' "$pane" | grep -qE "for agents|for shortcuts"; then break; fi
  done
fi

export CLAUDE_RELAY_SESSION="$KEY"

# Persistent-watcher model (opt-in via env or a relay-work/WATCH sentinel): keep
# ONE long-lived watcher per session in its own tmux session, so every turn --
# including long ones that finish after the inbound message is long gone -- gets
# delivered. The per-message call below then only injects.
if [ "${RELAY_WATCH:-0}" = "1" ] || [ -f "$DIR/relay-work/WATCH" ]; then
  WKEY="crw-${KEY#cr-}"
  if ! tmux has-session -t "$WKEY" 2>/dev/null; then
    # -c "$DIR": pin the watcher's cwd to the scripts dir so its child WS
    # edit-server (node relay-ws-edit-server.mjs) resolves the global openclaw
    # module. Launched from another cwd, node fails ERR_MODULE_NOT_FOUND and the
    # live progress bubble silently never draws.
    tmux new-session -d -s "$WKEY" -c "$DIR" \
      "CLAUDE_RELAY_SESSION='$KEY' RELAY_STREAM='${RELAY_STREAM:-1}' exec python3 '$DIR/claude-relay-send.py' --watch"
  fi
fi

exec python3 "$DIR/claude-relay-send.py" "$@"
