#!/usr/bin/env bash
# OpenClaw cliBackend command for a per-folder Claude TUI relay.
# Config bakes the folder into args[0]; OpenClaw appends the user message as the last arg.
set -uo pipefail
SCRIPTS="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"   # self-locate
FOLDER="${1:?folder arg required}"
BOUND_PEER=""
[ "$#" -ge 3 ] && BOUND_PEER="$2"
PROMPT="${@: -1}"

# Pull the Telegram chat id out of the RAW composed prompt (metadata JSON or the
# "[Telegram ... id:-123]" envelope) so the relay can send native buttons there.
CID="$(printf '%s' "$PROMPT" | grep -oE 'telegram:-?[0-9]{5,}' | head -1 | sed 's/telegram://')"
[ -z "$CID" ] && CID="$(printf '%s' "$PROMPT" | grep -oE 'id:-?[0-9]{5,}' | head -1 | sed 's/id://')"

# OpenClaw's prompt metadata stores the bare chat_id and topic_id separately.
# Reconstruct the canonical routing peer used by Telegram bindings.
TOPIC_ID="$(printf '%s' "$PROMPT" | grep -oE '"topic_id"[[:space:]]*:[[:space:]]*"?[0-9]+' | head -1 | grep -oE '[0-9]+$')"
[ -z "$TOPIC_ID" ] && TOPIC_ID="$(printf '%s' "$PROMPT" | grep -oE 'topic:[0-9]+' | head -1 | cut -d: -f2)"
PEER="${BOUND_PEER:-$CID}"
[ -z "$BOUND_PEER" ] && [ -n "$PEER" ] && [ -n "$TOPIC_ID" ] && PEER="${PEER}:topic:${TOPIC_ID}"
# PEER (with :topic:N) is the binding key for admin commands. Native message
# sends, however, need a NUMERIC chat id plus a SEPARATE thread id -- a
# "<id>:topic:N" target is rejected ("recipient must be a numeric chat ID").
NUM="$(printf '%s' "$PEER" | grep -oE '^-?[0-9]+' | head -1)"
export RELAY_CHAT_ID="${NUM:-$CID}"
export RELAY_THREAD_ID="$TOPIC_ID"

# Extract only the actual current user message from OpenClaw's composed prompt.
# Falls back to the original text if the expected markers aren't present.
RAW_PROMPT="$PROMPT"
PROMPT="$(printf '%s' "$PROMPT" | python3 $SCRIPTS/relay-extract-message.py)"
# Debug (opt-in): when relay-work/DEBUG exists, capture the composed prompt +
# what extraction yielded, so new prompt shapes can be diagnosed. Off by default.
if [ -f "$SCRIPTS/relay-work/DEBUG" ]; then
  { printf '\n===== %s len=%s =====\n--- RAW composed ---\n%s\n--- EXTRACTED ---\n%s\n' \
      "$(date '+%H:%M:%S')" "${#RAW_PROMPT}" "$RAW_PROMPT" "$PROMPT"; } \
      >> "$SCRIPTS/relay-work/backend-debug.log" 2>/dev/null || true
fi

# --- Admin-command interception (handled at the relay layer, NOT in the TUI) ---
# A bound chat routes EVERY message through this backend, so the bind/unbind/status
# admin commands must be caught HERE. If they fall through to the raw Claude Code
# session, that session hits a permission prompt, the gateway restart it triggers
# aborts it mid-turn, and on resume it re-runs the stale command -> restart loop.
# We run the scripts WITHOUT --restart and fire a detached, deferred restart so this
# reply flushes to the user before the gateway bounces. One-shot script = no re-run.
SCRIPTS="$SCRIPTS"
ADMIN="$(printf '%s' "$PROMPT" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | tr 'A-Z' 'a-z')"
defer_restart() { ( sleep 2; openclaw gateway restart ) >/dev/null 2>&1 & }
case "$ADMIN" in
  newcc\ *|new-cc\ *|"new cc "*|/newcc\ *|/new-cc\ *|/new-claude-code\ *)
    [ -z "$PEER" ] && { echo "Bind failed: couldn't determine this chat's id."; exit 0; }
    CODE="$(printf '%s' "$PROMPT" | grep -oE '[0-9]{6}' | head -1)"
    [ -z "$CODE" ] && { echo "Bind failed: need a 6-digit code, e.g. \`newcc 461156\`."; exit 0; }
    OUT="$(python3 "$SCRIPTS/bind-claude-code.py" --peer="$PEER" --code="$CODE" 2>&1)" && defer_restart
    printf '%s\n' "$OUT"
    exit 0 ;;
  /unbind|unbind|/unbind-claude-code)
    [ -z "$PEER" ] && { echo "Unbind failed: couldn't determine this chat's id."; exit 0; }
    OUT="$(python3 "$SCRIPTS/claude-code-admin.py" unbind --peer="$PEER" 2>&1)" && defer_restart
    printf '%s\n' "$OUT"
    exit 0 ;;
  /claude-code-status|claude-code-status|/cc-status)
    python3 "$SCRIPTS/claude-code-admin.py" status 2>&1
    exit 0 ;;
esac

# Slash-command passthrough: OpenClaw strips/handles real slash commands (/model,
# /clear, ...) before they reach here. Prefix with "cc" to forward one to Claude
# Code instead: "cc model sonnet" / "/cc model sonnet" -> types "/model sonnet" into
# the TUI. Matched CASE-INSENSITIVELY on the prefix, because phone keyboards
# auto-capitalize the first word ("cc" -> "Cc"), which silently broke the command.
# The rest of the line keeps its original case (arg values may be case-sensitive).
CC_LOWER="$(printf '%s' "$PROMPT" | tr 'A-Z' 'a-z')"
case "$CC_LOWER" in
  "/cc "*) PROMPT="/$(printf '%s' "$PROMPT" | cut -c5-)" ;;   # drop leading "/cc "
  "cc "*)  PROMPT="/$(printf '%s' "$PROMPT" | cut -c4-)" ;;   # drop leading "cc "
esac

# Final hop into the per-folder TUI session. Overridable for tests (a stub that
# echoes "$FOLDER" + "$PROMPT" lets us assert routing without launching a TUI).
exec bash "${RELAY_GROUP_CMD:-$SCRIPTS/claude-relay-group}" "$FOLDER" "$PROMPT"
